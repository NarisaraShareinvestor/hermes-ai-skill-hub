# ===========================
# PRODUCTION ENVIRONMENT FILE
# ===========================
# ⚠️  IMPORTANT: This file contains sensitive data. Never commit to git!
# ⚠️  Update all values before deploying to Hostinger

# ─────────────────────────────────
# DATABASE Configuration (Hostinger Managed or Docker)
# ─────────────────────────────────

# If using Hostinger Managed Database:
# DATABASE_URL=postgresql://your_db_user:your_db_password@your-managed-db-host.hostinger.com:5432/hermes_db

# If using Docker (local postgres):
DATABASE_URL=postgresql://hermes_user:CHANGE_ME_STRONG_PASSWORD@postgres:5432/hermes_db

DB_USER=hermes_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=hermes_db

# ─────────────────────────────────
# BACKEND Configuration
# ─────────────────────────────────
BACKEND_URL=https://your-domain.com
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ENVIRONMENT=production
DEBUG=False

# Generate a strong secret key using: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_GENERATE_STRONG_SECRET_KEY

# ─────────────────────────────────
# API Keys (Required)
# ─────────────────────────────────

# Anthropic API Key - https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME_YOUR_KEY

# OpenAI API Key - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-CHANGE_ME_YOUR_KEY

# ─────────────────────────────────
# Telegram Bot Configuration
# ─────────────────────────────────

# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=CHANGE_ME_BOT_TOKEN

# Your Telegram Channel ID (negative number for channels)
TELEGRAM_CHANNEL_ID=-100CHANGE_ME_CHANNEL_ID

# ─────────────────────────────────
# Domain Configuration
# ─────────────────────────────────
DOMAIN_NAME=your-domain.com

# ─────────────────────────────────
# n8n Configuration (Optional)
# ─────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─────────────────────────────────
# Redis Configuration
# ─────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─────────────────────────────────
# Email Configuration (Optional)
# ─────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@your-domain.com

# ─────────────────────────────────
# CORS Configuration
# ─────────────────────────────────
CORS_ORIGINS=["https://your-domain.com", "https://www.your-domain.com"]

# ─────────────────────────────────
# Logging Configuration
# ─────────────────────────────────
LOG_LEVEL=info
LOG_FILE=/var/log/hermes/app.log

# ─────────────────────────────────
# Security Configuration
# ─────────────────────────────────
ALLOWED_HOSTS=["your-domain.com", "www.your-domain.com"]
SESSION_TIMEOUT=3600

# ─────────────────────────────────
# Feature Flags
# ─────────────────────────────────
ENABLE_N8N=true
ENABLE_REDIS=true
ENABLE_TELEGRAM_BOT=true

# ===========================
# MinIO (object storage สำหรับรูปที่ extract จาก PDF)
# ===========================
# ตั้งรหัสจริง: openssl rand -hex 24  (ห้ามใช้ค่า default change_me_minio_secret)
MINIO_ROOT_USER=hermes_minio
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_strong_password
MINIO_BUCKET=hermes-docs

# ===========================
# INSTRUCTIONS
# ===========================
# 1. Copy this file to .env.production
# 2. Replace all CHANGE_ME_* values with actual values
# 3. Keep this file in a secure location
# 4. Never commit to git
# 5. Set proper permissions: chmod 600 .env.production
# 6. Use in docker-compose: docker-compose -f docker-compose.prod.yml --env-file .env.production up -d
